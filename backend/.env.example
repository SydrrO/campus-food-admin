# Optional: use SQLite locally instead of MySQL
DATABASE_URL_OVERRIDE=

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=campus_food

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_SCAN_SECONDS=30

# WeChat
WECHAT_PAY_MODE=mock
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
WECHAT_MCHID=your_mchid
WECHAT_API_KEY=your_api_key
WECHAT_API_V3_KEY=your_32_char_api_v3_key
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=your_merchant_cert_serial
WECHAT_PAY_PLATFORM_CERT_PATH=./certs/wechatpay_platform.pem
WECHAT_PAY_TIMEOUT_MINUTES=15

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# App
APP_ENV=development
APP_DEBUG=true
